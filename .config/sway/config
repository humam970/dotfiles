set $mod Mod4

exec swayosd-server
exec swayidle -w \
	timeout 300 'swaylock -f -c 000000' \
	timeout 600 'swaymsg "output * power off"' \
	resume 'swaymsg "output * power on"' \
	before-sleep 'swaylock -f -c 000000'

exec_always pidof wlsunset >/dev/null || wlsunset -s 00:00 -S 00:00 -t 4000


include /etc/sway/config.d/*
include ./opts.conf
include ./apps.conf
include ./binds.conf
include ./styles.conf
include ./bar.conf
include ./rules.conf
